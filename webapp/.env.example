# APP ID
NEXT_PUBLIC_APP_ID=
# APP API key
NEXT_PUBLIC_APP_KEY=
# API url prefix
NEXT_PUBLIC_API_URL=
# Project base path prefix (leave empty for root, e.g. /chat)
NEXT_PUBLIC_BASE_PATH=
# Default theme mode: light, dark, tech-blue, or system
NEXT_PUBLIC_DEFAULT_THEME=tech-blue

# Auth system (disabled by default for backward compatibility)
AUTH_ENABLED=false
JWT_SECRET=
