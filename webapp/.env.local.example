# APP ID
NEXT_PUBLIC_APP_ID=
# APP API key
NEXT_PUBLIC_APP_KEY=
# API url prefix
NEXT_PUBLIC_API_URL=
# Project base path prefix (leave empty for root, e.g. /chat)
NEXT_PUBLIC_BASE_PATH=
# Default theme mode: light, dark, or system
NEXT_PUBLIC_DEFAULT_THEME=light

# Storage backend: local | sqlite | postgres
NEXT_PUBLIC_STORAGE_BACKEND=local
# SQLite database path (server-side only, relative to webapp directory or absolute path)
SQLITE_DB_PATH=data/openchat.db
# PostgreSQL connection string (server-side only, future)
# POSTGRES_URL=postgresql://user:password@localhost:5432/openchat

# Auth system (disabled by default for backward compatibility)
AUTH_ENABLED=false
JWT_SECRET=
